# SBrandOps production environment

# Public client variables — ONLY public identifiers here, NEVER secrets
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_INSTAGRAM_CLIENT_ID=your_instagram_client_id
VITE_TWITTER_API_KEY=your_twitter_consumer_key
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id
VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key
VITE_APP_URL=https://sbrandops.com
VITE_API_URL=https://sbrandops.com/api
VITE_SENTRY_DSN=https://your_key@o0.ingest.sentry.io/0
VITE_APP_VERSION=1.0.0

# Public Paddle price references
VITE_PADDLE_ENV=live
VITE_PADDLE_STARTER_MONTHLY_PRICE_ID=pri_live_starter_monthly
VITE_PADDLE_STARTER_YEARLY_PRICE_ID=pri_live_starter_yearly
VITE_PADDLE_GROWTH_MONTHLY_PRICE_ID=pri_live_growth_monthly
VITE_PADDLE_GROWTH_YEARLY_PRICE_ID=pri_live_growth_yearly
VITE_PADDLE_AGENCY_MONTHLY_PRICE_ID=pri_live_agency_monthly
VITE_PADDLE_AGENCY_YEARLY_PRICE_ID=pri_live_agency_yearly

# Server-side / Edge secrets
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key_here
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here
PADDLE_STARTER_MONTHLY_PRICE_ID=pri_live_starter_monthly
PADDLE_STARTER_YEARLY_PRICE_ID=pri_live_starter_yearly
PADDLE_GROWTH_MONTHLY_PRICE_ID=pri_live_growth_monthly
PADDLE_GROWTH_YEARLY_PRICE_ID=pri_live_growth_yearly
PADDLE_AGENCY_MONTHLY_PRICE_ID=pri_live_agency_monthly
PADDLE_AGENCY_YEARLY_PRICE_ID=pri_live_agency_yearly
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret_here
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret_here
